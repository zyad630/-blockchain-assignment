# =====================================================
# Worklo ENVIRONMENT CONFIGURATION
# =====================================================
# Uses Supabase Cloud (no Docker required)
#
# SETUP:
#   1. Copy this file: cp .env.local.template .env.local
#   2. Fill in your Supabase cloud project credentials
#   3. Run: npm run dev
#   4. Open: http://localhost:3000

# =====================================================
# SUPABASE (CLOUD)
# =====================================================
# Get these from: https://supabase.com/dashboard → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =====================================================
# APP SETTINGS
# =====================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=debug
NODE_ENV=development

# Demo mode (set to true for quick-login buttons)
NEXT_PUBLIC_DEMO_MODE=false

# =====================================================
# SECURITY
# =====================================================

# Used to create the first superadmin account at /setup
# Generate with: openssl rand -hex 32
# SETUP_SECRET=change-me-to-something-secure

# Required for scheduled cron jobs
# CRON_SECRET=change-me-to-something-secure

# =====================================================
# SMTP (for invitation emails)
# =====================================================
# SMTP_HOST=smtp.your-domain.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=Worklo <noreply@your-domain.com>

# =====================================================
# OPTIONAL: RATE LIMITING
# =====================================================
# UPSTASH_REDIS_REST_URL=your_upstash_redis_url
# UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token
# ENABLE_RATE_LIMIT=true

# =====================================================
# BLOCKCHAIN (Hardhat local node + WPT contract)
# =====================================================
# 1. Start a local Hardhat node:  npx hardhat node
# 2. Deploy the contract:         npx hardhat run scripts/deploy.ts --network localhost
# 3. Copy the printed values below:

# RPC URL of the local Hardhat node (default shown)
HARDHAT_RPC_URL=http://127.0.0.1:8545

# Address of the deployed WorkloProjectToken contract (printed after deploy)
WPT_CONTRACT_ADDRESS=0x_your_deployed_contract_address_here

# Private key of the Hardhat deployer account (Account #0 from `npx hardhat node` output)
# NEVER use a real private key here — Hardhat test keys only!
WPT_OWNER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Wallet address that receives the WPT tokens (defaults to Hardhat Account #1 if not set)
# WPT_RECIPIENT_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
